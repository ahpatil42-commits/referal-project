# ─────────────────────────────────────────────────────────────
# ReferralAI — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── NextAuth v5 ───────────────────────────────────────────────
AUTH_SECRET="at-least-32-characters-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth Providers (all optional for local dev) ──────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""
AUTH_LINKEDIN_ID=""
AUTH_LINKEDIN_SECRET=""

# ── Google Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY=""

# ── Email (Resend — https://resend.com) ───────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ── Real-time (Pusher — https://pusher.com) ───────────────────
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# ── File Uploads (Vercel Blob) ────────────────────────────────
# Create a Blob store in your Vercel project settings
BLOB_STORE_ID=""
BLOB_READ_WRITE_TOKEN=""

# ── Stripe Payments ───────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Rate Limiting (Upstash Redis — https://upstash.com) ───────
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# ── ATS Integration (encrypt API keys stored in DB) ───────────
# Must be exactly 32 characters
ENCRYPTION_KEY=""

# ── Error Tracking (Sentry — optional) ───────────────────────
SENTRY_DSN=""

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Supabase Auth ─────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # Server-only, never expose to browser
