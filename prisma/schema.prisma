// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: SQLite does not support native enums.
// Role is stored as a String; valid values are "SEEKER" | "REFERRER".
// Request status values: "PENDING" | "ACCEPTED" | "REJECTED" | "COMPLETED"
// Enforced at the application layer via Zod and TypeScript.

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String          @default("SEEKER")
  isAdmin       Boolean         @default(false)
  isSuspended   Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Stripe Monetization
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  plan                 String    @default("FREE")
  credits              Int       @default(1)


  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // Profile relations (one-to-one)
  seekerProfile   SeekerProfile?
  referrerProfile ReferrerProfile?

  // Messages sent by this user
  messages        Message[] @relation("UserMessages")
  
  // Notifications received by this user
  notifications   Notification[]
}

model SeekerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline       String?
  bio            String?
  skills         String?  // JSON-encoded string[]
  resumeUrl      String?
  resumeStoragePath String? // Local filesystem path to the uploaded PDF
  linkedinUrl    String?
  githubUrl      String?
  targetRoles    String?  // JSON-encoded string[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sentRequests   ReferralRequest[] @relation("SeekerRequests")
}

model ReferrerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  corporateEmail String?
  company        String?
  jobTitle       String?
  yearsAtCompany Int?
  bio            String?
  linkedinUrl    String?
  maxReferrals   Int      @default(3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  receivedRequests ReferralRequest[] @relation("ReferrerRequests")
  referralPostings ReferralPosting[] @relation("ReferrerPostings")
}

// Core product model: a seeker requesting a referral from a referrer
model ReferralRequest {
  id          String   @id @default(cuid())
  seekerId    String
  referrerId  String
  jobTitle    String
  company     String
  jobUrl      String?
  coverNote   String   // Seeker's personal message to the referrer
  status      String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | COMPLETED
  referrerNote String? // Optional note from referrer on accept/reject
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seeker   SeekerProfile   @relation("SeekerRequests",   fields: [seekerId],   references: [id], onDelete: Cascade)
  referrer ReferrerProfile @relation("ReferrerRequests", fields: [referrerId], references: [id], onDelete: Cascade)
  messages Message[]
}

model ReferralPosting {
  id          String   @id @default(cuid())
  referrerId  String
  jobTitle    String
  company     String
  jobUrl      String?
  description String?  // Optional JD summary
  experience  String?
  skills      String?
  location    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  referrer    ReferrerProfile @relation("ReferrerPostings", fields: [referrerId], references: [id], onDelete: Cascade)
}

model Message {
  id          String   @id @default(cuid())
  requestId   String
  senderId    String   // User ID of the sender
  content     String
  createdAt   DateTime @default(now())

  request     ReferralRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender      User            @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?  
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
